# Pyonex environment — copy to .env and fill in

# Exchange data (public endpoints usually work key-less; set only if rate-limited)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Pionex read-only (Phase 4 stub)
PIONEX_API_KEY=
PIONEX_API_SECRET=

# Telegram alerts (Phase 3 stub)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App
PYONEX_DB_PATH=pyonex.db
PYONEX_LOG_LEVEL=INFO
